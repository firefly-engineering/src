# Managed by turnkey - cells under .turnkey/ are generated on shell entry

[cells]
  root = .
  toolchains = .turnkey/toolchains
  prelude = .turnkey/prelude
  none = none
  godeps = .turnkey/godeps
  rustdeps = .turnkey/rustdeps

[cell_aliases]
  config = prelude
  ovr_config = prelude
  fbcode = none
  fbsource = none
  fbcode_macros = none
  buck = none

[parser]
  target_platform_detector_spec = target:root//...->prelude//platforms:default \
    target:toolchains//...->prelude//platforms:default \
    target:prelude//...->prelude//platforms:default \
    target:godeps//...->prelude//platforms:default \
    target:rustdeps//...->prelude//platforms:default

[build]
  execution_platforms = prelude//platforms:default

[project]
  # when using jujutsu
  ignore = .jj
