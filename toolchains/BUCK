load("@prelude//toolchains:cxx.bzl", "system_cxx_toolchain")

# Explicit system toolchains for Rust, Go, Python, and C++
system_rust_toolchain(
    name = "rust",
    visibility = ["PUBLIC"],
)

system_go_toolchain(
    name = "go",
    visibility = ["PUBLIC"],
)

system_python_bootstrap_toolchain(
    name = "python_bootstrap",
    visibility = ["PUBLIC"],
)

system_cxx_toolchain(
    name = "cxx",
    visibility = ["PUBLIC"],
)